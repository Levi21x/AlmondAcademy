SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret
ALLOWED_ORIGINS=http://localhost:3000
ENVIRONMENT=development
APP_NAME=AlmondAI
GROQ_API_KEY=
